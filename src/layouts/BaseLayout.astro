---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  fullscreen?: boolean;
}

const {
  title,
  description = 'HYPR Station — Plataforma de mapas de cobertura de mídia. Rádio, celular e TV.',
  fullscreen = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | HYPR Station</title>
  <meta name="description" content={description} />

  <!-- Favicons -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- OG -->
  <meta property="og:title" content={`${title} | HYPR Station`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://stations.hypr.mobi/og-image.png" />
  <meta property="og:url" content="https://stations.hypr.mobi" />
  <meta property="og:site_name" content="HYPR Station" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | HYPR Station`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://stations.hypr.mobi/og-image.png" />

  <!-- Fonts: Urbanist (self-hosted) -->
  <link rel="preload" href="/fonts/urbanist-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/urbanist-latin-ext.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Theme: apply before paint to avoid flash. Runs on initial load AND
       after astro:after-swap so the class survives View Transitions. -->
  <script is:inline>
    (function () {
      const apply = () => {
        const t = localStorage.getItem('hypr-theme') || 'dark';
        if (t === 'light') document.documentElement.classList.add('light');
        else document.documentElement.classList.remove('light');
      };
      apply();
      document.addEventListener('astro:after-swap', apply);
    })();
  </script>

  <!-- Global CSS (Tailwind + tokens) -->
  <style>
    @import '../styles/global.css';

    /* View transition names — smooth crossfade between pages. Map pages
       (fullscreen) get a slightly longer fade so the map canvas re-hydrates
       gracefully. The default Astro transition is instant-swap; overriding
       the root name gives us a single fade. */
    @view-transition {
      navigation: auto;
    }

    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation-duration: 220ms;
      animation-timing-function: cubic-bezier(0.32, 0.72, 0, 1);
    }

    ::view-transition-old(root) {
      animation-name: vtFadeOut;
    }
    ::view-transition-new(root) {
      animation-name: vtFadeIn;
    }

    @keyframes vtFadeOut {
      to { opacity: 0; }
    }
    @keyframes vtFadeIn {
      from { opacity: 0; }
    }

    /* Respect reduced-motion for page transitions too. */
    @media (prefers-reduced-motion: reduce) {
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 0.01ms;
      }
    }
  </style>

  <ClientRouter />

  <!-- Per-page head content -->
  <slot name="head" />
</head>
<body class:list={[fullscreen && 'h-screen overflow-hidden']}>
  <slot />
</body>
</html>
